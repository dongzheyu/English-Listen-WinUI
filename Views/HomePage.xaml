<Page
    x:Class="English_Listen_WinUI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Welcome Message (Centered) -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="WelcomeLabel" 
                       Text="欢迎使用英语听写训练系统"
                       FontSize="36" FontWeight="Bold" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- User Status (Top Right) -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20,20,20,0">
                <TextBlock x:Name="UserStatusLabel" 
                           Text="👤 未登录"
                           FontSize="14" Foreground="Gray" 
                           Tapped="UserStatusLabel_Tapped"/>
                <Button x:Name="LogoutButton" Content="退出" 
                        Click="LogoutButton_Click" 
                        Visibility="Collapsed" 
                        Margin="10,0,0,0" 
                        Height="25" FontSize="12"/>
            </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <Button x:Name="StartButton" Content="开始听写测试" 
                        Click="StartButton_Click" Width="160" Height="45" Margin="10"
                        Style="{StaticResource AccentButtonStyle}"/>
                <Button x:Name="ViewWordsButton" Content="查看单词" 
                        Click="ViewWordsButton_Click" Width="120" Height="40" Margin="10"/>
                <Button x:Name="ProgressButton" Content="学习进度" 
                        Click="ProgressButton_Click" Width="120" Height="40" Margin="10"
                        IsEnabled="False"/>
                <Button x:Name="SettingsButton" Content="设置" 
                        Click="SettingsButton_Click" Width="120" Height="40" Margin="10"/>
                <Button x:Name="AboutButton" Content="关于" 
                        Click="AboutButton_Click" Width="120" Height="40" Margin="10"/>
                <Button x:Name="GuideButton" Content="使用指南" 
                        Click="GuideButton_Click" Width="120" Height="40" Margin="10"/>
            </StackPanel>

            <!-- Quick Stats -->
            <StackPanel x:Name="StatsPanel" Orientation="Horizontal" 
                        HorizontalAlignment="Center" Margin="20" Visibility="Collapsed">
                <TextBlock x:Name="TotalTestsText" Text="总测试次数: 0" Margin="20"/>
                <TextBlock x:Name="AvgAccuracyText" Text="平均正确率: 0%" Margin="20"/>
            </StackPanel>
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <TextBlock Text="English Listen v2.7.0 | 智能英语听写训练系统" FontSize="12" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Page>
