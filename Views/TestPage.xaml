<Page
    x:Class="English_Listen_WinUI.Views.TestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="800"
    KeyDown="Page_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header - Matching QT6 exactly -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,10,10,5">
            <TextBlock Text="听写测试" FontSize="24" FontWeight="Bold" 
                       FontFamily="Microsoft YaHei"
                       VerticalAlignment="Center" Margin="20,10,20,10"/>
            <TextBlock x:Name="ProgressText" Text="第 0 / 0 个单词" 
                       VerticalAlignment="Center" FontSize="16" Margin="20,10,20,10"
                       FontFamily="Microsoft YaHei"/>
        </StackPanel>

        <!-- Main Content - Matching QT6 QVBoxLayout structure -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            
            <!-- Countdown Label - QT6 style 48pt font -->
            <TextBlock x:Name="CountdownLabel" Text="5" 
                       FontSize="48" FontWeight="Bold"
                       FontFamily="Microsoft YaHei"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- Online Dictation Input Area (hidden by default) -->
            <StackPanel x:Name="OnlineInputPanel" Visibility="Collapsed" Margin="0,0,0,20">
                <TextBlock Text="请输入听到的单词：" FontSize="16" Margin="5" HorizontalAlignment="Center"
                           FontFamily="Microsoft YaHei"/>
                <TextBox x:Name="OnlineInputTextBox" Width="300" Height="40" FontSize="18" 
                         HorizontalAlignment="Center" PlaceholderText="请输入听到的单词..."
                         FontFamily="Microsoft YaHei"
                         KeyDown="OnlineInputTextBox_KeyDown"/>
                <TextBlock x:Name="OnlineStatusLabel" Text="" FontSize="14" FontWeight="Bold" 
                           Margin="5" HorizontalAlignment="Center" FontFamily="Microsoft YaHei"/>
            </StackPanel>

            <!-- Current Word Display - QT6 style without background color -->
            <Border x:Name="WordDisplayBorder" 
                    Background="{ThemeResource SystemAccentColor}" 
                    CornerRadius="10" Padding="40" Margin="0,0,0,20"
                    Visibility="Collapsed">
                <TextBlock x:Name="CurrentWordText" Text="准备开始" 
                           FontSize="36" FontWeight="Bold"
                           Foreground="White"
                           FontFamily="Microsoft YaHei"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Settings Panel - QT6 style with interval controls -->
            <StackPanel x:Name="SettingsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="时间间隔(秒):" VerticalAlignment="Center" Margin="0,0,10,0"
                           FontFamily="Microsoft YaHei" FontSize="14"/>
                <NumberBox x:Name="IntervalNumberBox" Width="80" Height="35" 
                           Minimum="2" Maximum="10" Value="5" SpinButtonPlacementMode="Inline"
                           FontFamily="Microsoft YaHei" FontSize="14"/>
                <Button x:Name="ApplyIntervalButton" Content="应用" Width="60" Height="35" Margin="10,0,0,0"
                        Click="ApplyIntervalButton_Click" FontFamily="Microsoft YaHei" FontSize="14"/>
            </StackPanel>

            <!-- Control Buttons - QT6 style with proper spacing -->
            <StackPanel x:Name="PaperModeButtons" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Button x:Name="PreviousButton" Content="上一个" 
                        Click="PreviousButton_Click" Width="120" Height="35" Margin="0,0,15,0"
                        FontFamily="Microsoft YaHei" FontSize="14"/>
                <Button x:Name="RepeatButton" Content="再读一遍" 
                        Click="RepeatButton_Click" Width="120" Height="35" Margin="0,0,15,0"
                        FontFamily="Microsoft YaHei" FontSize="14"/>
                <Button x:Name="NextButton" Content="下一个" 
                        Click="NextButton_Click" Width="120" Height="35" Margin="0,0,15,0"
                        FontFamily="Microsoft YaHei" FontSize="14"/>
                <Button x:Name="PauseButton" Content="暂停" 
                        Click="PauseButton_Click" Width="120" Height="35" Margin="0,0,15,0"
                        FontFamily="Microsoft YaHei" FontSize="14"/>
                <Button x:Name="ExitTestButton" Content="退出测试" 
                        Click="ExitTestButton_Click" Width="120" Height="35"
                        FontFamily="Microsoft YaHei" FontSize="14"/>
            </StackPanel>
            
            <!-- Online Mode Buttons - QT6 style -->
            <StackPanel x:Name="OnlineModeButtons" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10" Visibility="Collapsed">
                <Button x:Name="RepeatButtonOnline" Content="再读一遍" 
                        Click="RepeatButton_Click" Width="120" Height="35" Margin="0,0,15,0"
                        FontFamily="Microsoft YaHei" FontSize="14"/>
                <Button x:Name="PauseButtonOnline" Content="暂停" 
                        Click="PauseButton_Click" Width="120" Height="35" Margin="0,0,15,0"
                        FontFamily="Microsoft YaHei" FontSize="14"/>
                <Button x:Name="OnlineSubmitButton" Content="提交所有答案" 
                        Click="OnlineSubmitButton_Click" Width="120" Height="35" Margin="0,0,15,0"
                        FontFamily="Microsoft YaHei" FontSize="14"/>
                <Button x:Name="ExitTestButtonOnline" Content="退出测试" 
                        Click="ExitTestButton_Click" Width="120" Height="35"
                        FontFamily="Microsoft YaHei" FontSize="14"/>
            </StackPanel>
        </StackPanel>

        <!-- Hint - QT6 style note -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="10,5,10,20">
            <TextBlock Text="注意：点击'下一个'按钮将跳过当前单词并立即播放下一个单词" 
                       FontSize="12" Foreground="Gray" FontFamily="Microsoft YaHei"/>
            <TextBlock Text="快捷键: 空格=朗读 | 左=上一词 | 右=下一词 | ESC=暂停 | 在线模式: 回车=提交答案" 
                       FontSize="12" Foreground="Gray" Margin="0,5,0,0" FontFamily="Microsoft YaHei"/>
        </StackPanel>
    </Grid>
</Page>
