<Page
    x:Class="English_Listen_WinUI.Views.TestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="800"
    KeyDown="Page_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <TextBlock Text="听写测试" FontSize="24" FontWeight="Bold" 
                       VerticalAlignment="Center" Margin="20"/>
            <TextBlock x:Name="ProgressText" Text="0/0" 
                       VerticalAlignment="Center" FontSize="16" Margin="20"/>
        </StackPanel>

        <!-- Main Content -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Countdown -->
            <TextBlock x:Name="CountdownLabel" Text="5" 
                       FontSize="72" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="20"/>

            <!-- Online Dictation Input Area (hidden by default) -->
            <StackPanel x:Name="OnlineInputPanel" Visibility="Collapsed" Margin="20">
                <TextBlock Text="请输入听到的单词：" FontSize="16" Margin="5" HorizontalAlignment="Center"/>
                <TextBox x:Name="OnlineInputTextBox" Width="300" Height="40" FontSize="18" 
                         HorizontalAlignment="Center" PlaceholderText="输入单词..."
                         KeyDown="OnlineInputTextBox_KeyDown"/>
                <TextBlock x:Name="OnlineStatusLabel" Text="" FontSize="14" FontWeight="Bold" 
                           Margin="5" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Current Word Display -->
            <Border x:Name="WordDisplayBorder" 
                    Background="{ThemeResource SystemAccentColor}" 
                    CornerRadius="10" Padding="40" Margin="20">
                <TextBlock x:Name="CurrentWordText" Text="Ready" 
                           FontSize="48" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Control Buttons -->
            <StackPanel x:Name="PaperModeButtons" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
                <Button x:Name="PreviousButton" Content="上一个" 
                        Click="PreviousButton_Click" Width="100" Height="40" Margin="10"/>
                <Button x:Name="RepeatButton" Content="再读一遍" 
                        Click="RepeatButton_Click" Width="100" Height="40" Margin="10"/>
                <Button x:Name="NextButton" Content="下一个" 
                        Click="NextButton_Click" Width="100" Height="40" Margin="10"/>
                <Button x:Name="PauseButton" Content="暂停" 
                        Click="PauseButton_Click" Width="100" Height="40" Margin="10"/>
                <Button x:Name="ExitTestButton" Content="退出测试" 
                        Click="ExitTestButton_Click" Width="100" Height="40" Margin="10"/>
            </StackPanel>
            
            <!-- Online Mode Buttons -->
            <StackPanel x:Name="OnlineModeButtons" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20" Visibility="Collapsed">
                <Button x:Name="RepeatButtonOnline" Content="再读一遍" 
                        Click="RepeatButton_Click" Width="100" Height="40" Margin="10"/>
                <Button x:Name="PauseButtonOnline" Content="暂停" 
                        Click="PauseButton_Click" Width="100" Height="40" Margin="10"/>
                <Button x:Name="OnlineSubmitButton" Content="提交答案" 
                        Click="OnlineSubmitButton_Click" Width="100" Height="40" Margin="10"/>
                <Button x:Name="ExitTestButtonOnline" Content="退出测试" 
                        Click="ExitTestButton_Click" Width="100" Height="40" Margin="10"/>
            </StackPanel>

            <!-- Settings -->
            <StackPanel x:Name="SettingsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
                <TextBlock Text="朗读间隔:" VerticalAlignment="Center" Margin="5"/>
                <Slider x:Name="IntervalSlider" Width="150" 
                        Minimum="1" Maximum="60" Value="5"
                        ValueChanged="IntervalSlider_ValueChanged"/>
                <TextBlock x:Name="IntervalText" Text="5秒" 
                           VerticalAlignment="Center" Margin="5"/>
            </StackPanel>
        </StackPanel>

        <!-- Hint -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="20">
            <TextBlock Text="注意：纸笔听写模式下点击'下一个'按钮将跳过当前单词并立即播放下一个单词" 
                       FontSize="12" Foreground="Gray"/>
            <TextBlock Text="快捷键: 空格=朗读 | 左=上一词 | 右=下一词 | ESC=暂停 | 在线模式: 回车=提交答案" 
                       FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</Page>
