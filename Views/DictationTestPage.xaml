<Page
    x:Class="English_Listen_WinUI.Views.DictationTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部区域 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock x:Name="TitleText" Text="听写测试" FontSize="24" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,30,0"/>
            <TextBlock x:Name="ProgressText" Text="第 0 / 0 个"
                       VerticalAlignment="Center" FontSize="16" Margin="0,0,30,0"/>
            <TextBlock x:Name="ScoreText" Text="正确: 0 / 0"
                       VerticalAlignment="Center" FontSize="16"/>
            <TextBlock Text="倒计时:" VerticalAlignment="Center" Margin="30,0,10,0"/>
            <NumberBox x:Name="CountdownSetter" Width="80" Height="35"
                       Minimum="1" Maximum="60" Value="10"
                       SpinButtonPlacementMode="Compact"
                       ValueChanged="CountdownSetter_ValueChanged"/>
        </StackPanel>

        <!-- 中间区域 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- 输入框 -->
            <TextBox x:Name="InputTextBox"
                     Width="300" Height="40"
                     FontSize="18"
                     PlaceholderText="输入你听到的内容"
                     Margin="0,0,0,20"
                     KeyDown="InputTextBox_KeyDown"/>

            <!-- 翻译显示 -->
            <TextBlock x:Name="TranslationText" Text="" 
                       FontSize="16" 
                       Foreground="#666666" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <!-- 按钮行: 提交, 重播, 上一个, 下一个, 结束测试 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <Button x:Name="SubmitButton" Content="提交"
                        Width="90" Height="40" Margin="0,0,10,0"
                        Click="SubmitButton_Click"/>
                <Button x:Name="ReplayButton" Content="重播"
                        Width="90" Height="40" Margin="0,0,10,0"
                        Click="ReplayButton_Click"/>
                <Button x:Name="PreviousButton" Content="上一个"
                        Width="90" Height="40" Margin="0,0,10,0"
                        Click="PreviousButton_Click"/>
                <Button x:Name="SkipButton" Content="下一个"
                        Width="90" Height="40" Margin="0,0,10,0"
                        Click="SkipButton_Click"/>
                <Button x:Name="EndButton" Content="结束测试"
                        Width="90" Height="40"
                        Click="EndButton_Click"/>
            </StackPanel>

            <!-- 状态文本 -->
            <TextBlock x:Name="SpeakingStatusText" Text=""
                       FontSize="14" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock x:Name="CountdownText" Text=""
                       FontSize="16" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
