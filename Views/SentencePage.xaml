<Page
    x:Class="English_Listen_WinUI.Views.SentencePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:English_Listen_WinUI.Views">

    <Grid>
        <Image Source="ms-appx:///background/default.jpg" Stretch="UniformToFill" />
        <Rectangle Fill="#FF000000" Opacity="0.65" />
        
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题和搜索 -->
            <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,20">
                <TextBlock Text="例句学习" Style="{ThemeResource HeaderTextBlockStyle}"/>
                <TextBox x:Name="SearchBox" PlaceholderText="搜索单词、例句或分类..." TextChanged="SearchBox_TextChanged"/>
            </StackPanel>

            <!-- 分类选择 -->
            <ComboBox Grid.Row="1" x:Name="CategoryComboBox" Header="选择分类" Margin="0,0,0,15" SelectionChanged="CategoryComboBox_SelectionChanged"/>

            <!-- 状态信息 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,0,0,15">
                <TextBlock x:Name="LoadedCountText" 
                          Style="{ThemeResource CaptionTextBlockStyle}" />
                <TextBlock x:Name="SelectedCountText" 
                          Style="{ThemeResource CaptionTextBlockStyle}" />
            </StackPanel>

            <!-- 例句列表 -->
            <ScrollViewer Grid.Row="3" Margin="0,0,0,15">
                <ListView x:Name="SentencesListView" SelectionMode="None" IsItemClickEnabled="False">
                    <!-- 这里将动态添加例句项 -->
                </ListView>
            </ScrollViewer>

            <!-- 控制按钮 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                <Button x:Name="PlayAllButton" Content="🔊 播放选中" Click="PlayAllButton_Click" Style="{ThemeResource AccentButtonStyle}"/>
                <Button x:Name="ClearSelectionButton" Content="清除选择" Click="ClearSelectionButton_Click"/>
                <Button x:Name="SelectAllButton" Content="全选" Click="SelectAllButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>