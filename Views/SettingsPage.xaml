<Page
    x:Class="English_Listen_WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="400" d:DesignWidth="500">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <TextBlock Text="设置" 
                        Style="{ThemeResource TitleTextBlockStyle}"
                       VerticalAlignment="Center" Margin="20"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="20">
            <StackPanel Spacing="15">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="主题设置" 
                                    Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,10"/>
                        <ComboBox x:Name="ThemeComboBox" Width="200"
                                  HorizontalAlignment="Left"
                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem Content="浅色" Tag="0"/>
                            <ComboBoxItem Content="深色" Tag="1"/>
                            <ComboBoxItem Content="跟随系统" Tag="2"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="朗读设置" 
                                    Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,15"/>
                        
                        <StackPanel Margin="0,10">
                            <TextBlock Text="朗读时间间隔(秒):" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,5"/>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                                <Slider x:Name="IntervalSlider" Grid.Column="0" Grid.Row="0"
                                        Minimum="1" Maximum="30" Value="5"
                                        ValueChanged="IntervalSlider_ValueChanged"/>
                                <TextBlock x:Name="IntervalText" Grid.Column="1" Grid.Row="0" 
                                           Text="5秒" 
                                           VerticalAlignment="Center" Margin="10,0,0,0"
                                           Style="{ThemeResource BodyTextBlockStyle}"/>
                            </Grid>
                        </StackPanel>
                        
                        <StackPanel Margin="0,15,0,10">
                            <TextBlock Text="语音引擎:" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,5"/>
                            <ComboBox x:Name="EngineComboBox" 
                                      SelectionChanged="EngineComboBox_SelectionChanged">
                                <ComboBoxItem Content="自动选择" Tag="Auto"/>
                                <ComboBoxItem Content="Windows系统语音" Tag="WindowsTTS"/>

                            </ComboBox>
                            <TextBlock x:Name="EngineStatusText" Text="" 
                                       Style="{ThemeResource CaptionTextBlockStyle}" 
                                       Foreground="{ThemeResource TextFillColorSecondary}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        
                        <!-- Windows TTS 语音选择 -->
                        <StackPanel Margin="0,15,0,10" x:Name="WindowsTtsVoicePanel" Visibility="Collapsed">
                            <TextBlock Text="系统语音:" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,5"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <ComboBox x:Name="WindowsTtsVoiceComboBox" Grid.Column="0"
                                          SelectionChanged="WindowsTtsVoiceComboBox_SelectionChanged"/>
                                <Button x:Name="WindowsTtsPreviewButton" Grid.Column="1" 
                                        Content="试听" Margin="10,0,0,0" Width="60"
                                        Click="WindowsTtsPreviewButton_Click"/>
                            </Grid>
                        </StackPanel>
                        

                        
                        <CheckBox x:Name="RandomOrderCheckBox" Content="随机播放单词" 
                                  Checked="RandomOrderCheckBox_Changed" 
                                  Unchecked="RandomOrderCheckBox_Changed"
                                  Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="百度翻译API设置" 
                                    Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,15"/>
                        
                        <StackPanel Margin="0,10">
                            <TextBlock Text="API模式:" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,5"/>
                            <ComboBox x:Name="TranslateApiModeComboBox" Width="200"
                                      HorizontalAlignment="Left"
                                      SelectionChanged="TranslateApiModeComboBox_SelectionChanged">
                                <ComboBoxItem Content="默认API" Tag="default"/>
                                <ComboBoxItem Content="自定义API" Tag="custom"/>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Margin="0,15,0,10" x:Name="CustomApiPanel" Visibility="Collapsed">
                            <TextBlock Text="API Key:" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,5"/>
                            <TextBox x:Name="ApiKeyTextBox" Width="300"
                                     PlaceholderText="请输入百度翻译API Key"
                                     TextChanged="ApiKeyTextBox_TextChanged"/>
                        </StackPanel>
                        
                        <StackPanel Margin="0,15,0,10">
                            <TextBlock Text="剩余翻译限额:" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,5"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock x:Name="TranslationLimitText" Text="--" 
                                           Style="{ThemeResource BodyTextBlockStyle}" VerticalAlignment="Center"/>
                                <Button x:Name="ClaimLimitButton" Grid.Column="1" 
                                        Content="领取限额" Margin="10,0,0,0" Width="100"
                                        Click="ClaimLimitButton_Click"/>
                            </Grid>
                        </StackPanel>
                        
                        <StackPanel Margin="0,15,0,10">
                            <TextBlock Text="获取API Key:" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,5"/>
                            <HyperlinkButton Content="前往百度翻译开放平台" 
                                            NavigateUri="https://fanyi-api.baidu.com/" 
                                            Click="HyperlinkButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="系统设置" 
                                   Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,15"/>
                        
                        <!-- 更新设置 -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="更新设置" 
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,5"/>
                            <TextBlock x:Name="CurrentVersionLabel" Text="当前版本: v2.7.0" 
                                       Style="{ThemeResource BodyTextBlockStyle}" Margin="0,0,0,5"/>
                            <TextBlock Text="点击检查更新按钮将会连接到服务器检查是否有新版本可用。如果有新版本，程序会自动下载并安装。" 
                                       Style="{ThemeResource CaptionTextBlockStyle}" 
                                       TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <Button x:Name="CheckUpdateButton" Content="检查更新" 
                                    Click="CheckUpdateButton_Click" 
                                    Style="{ThemeResource AccentButtonStyle}"
                                    HorizontalAlignment="Left"/>
                            <TextBlock x:Name="UpdateStatusText" Text="" 
                                       Style="{ThemeResource CaptionTextBlockStyle}" 
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        
                        <Button Content="初始化程序" Click="InitializeButton_Click" 
                                Style="{ThemeResource AccentButtonStyle}"
                                HorizontalAlignment="Left"/>
                        <TextBlock x:Name="VersionLabel" Text="当前版本: v2.7.0" 
                                   Style="{ThemeResource BodyTextBlockStyle}" Margin="0,10,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>