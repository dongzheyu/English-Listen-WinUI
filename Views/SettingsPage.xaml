<Page
    x:Class="English_Listen_WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <TextBlock Text="设置" FontSize="24" FontWeight="Bold" 
                       VerticalAlignment="Center" Margin="20"/>
        </StackPanel>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" Margin="20">
            <StackPanel>
                <!-- Theme Settings -->
                <TextBlock Text="主题设置" FontSize="18" FontWeight="Bold" Margin="10"/>
                <StackPanel Orientation="Horizontal" Margin="20">
                    <Button x:Name="ThemeToggleButton" Content="切换到浅色主题" 
                            Click="ThemeToggleButton_Click" Width="180" Height="50" Margin="10"/>
                </StackPanel>

                <!-- Speech Settings -->
                <TextBlock Text="朗读设置" FontSize="18" FontWeight="Bold" Margin="10"/>
                <StackPanel Margin="20">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <TextBlock Text="朗读时间间隔(秒):" Width="150" VerticalAlignment="Center"/>
                        <Slider x:Name="IntervalSlider" Width="200" 
                                Minimum="1" Maximum="60" Value="5"
                                ValueChanged="IntervalSlider_ValueChanged"/>
                        <TextBlock x:Name="IntervalText" Text="5秒" 
                                   VerticalAlignment="Center" Margin="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <TextBlock Text="朗读引擎:" Width="150" VerticalAlignment="Center"/>
                        <ComboBox x:Name="SpeechEngineComboBox" Width="200"
                                  SelectionChanged="SpeechEngineComboBox_SelectionChanged">
                            <ComboBoxItem Content="SAPI (Windows内置)" Tag="0"/>
                            <ComboBoxItem Content="Flite (第三方引擎)" Tag="1"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <TextBlock Text="SAPI语音:" Width="150" VerticalAlignment="Center"/>
                        <ComboBox x:Name="SapiVoiceComboBox" Width="200"/>
                        <Button Content="试听" Click="PreviewButton_Click" Margin="10" Width="80" Height="40"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <TextBlock Text="Flite语音模型:" Width="150" VerticalAlignment="Center"/>
                        <ComboBox x:Name="VoiceModelComboBox" Width="200">
                            <ComboBoxItem Content="cmu_us_slt (女声)"/>
                            <ComboBoxItem Content="cmu_us_awb (男声)"/>
                            <ComboBoxItem Content="cmu_us_bdl (男声)"/>
                            <ComboBoxItem Content="cmu_us_jmk (男声)"/>
                            <ComboBoxItem Content="cmu_us_ksp (男声)"/>
                            <ComboBoxItem Content="cmu_us_rms (男声)"/>
                        </ComboBox>
                        <Button Content="试听" Click="PreviewButton_Click" Margin="10" Width="80" Height="40"/>
                    </StackPanel>
                    <TextBlock Text="不同语音模型会产生不同的语音效果，您可以根据喜好选择合适的语音模型。点击试听按钮可预览效果。" 
                               TextWrapping="Wrap" Margin="10" Foreground="Gray"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <CheckBox x:Name="RandomOrderCheckBox" Content="随机播放单词" 
                                  Checked="RandomOrderCheckBox_Checked" Unchecked="RandomOrderCheckBox_Unchecked"/>
                    </StackPanel>
                </StackPanel>

                <!-- Security Settings -->
                <TextBlock Text="安全设置" FontSize="18" FontWeight="Bold" Margin="10"/>
                <StackPanel Margin="20">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <CheckBox x:Name="EncryptionCheckBox" Content="启用数据加密" 
                                  Checked="EncryptionCheckBox_Checked" Unchecked="EncryptionCheckBox_Unchecked"/>
                    </StackPanel>
                    <TextBlock Text="启用数据加密可以保护您的用户数据不被未授权访问。加密模式下需要输入密码才能登录。" 
                               TextWrapping="Wrap" Margin="10" Foreground="Gray"/>
                    <Button Content="初始化程序" Click="InitializeButton_Click" 
                            Width="180" Height="50" Margin="10" 
                            Style="{StaticResource AccentButtonStyle}"/>
                </StackPanel>

                <!-- Privacy Settings -->
                <TextBlock Text="隐私设置" FontSize="18" FontWeight="Bold" Margin="10"/>
                <StackPanel Margin="20">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <CheckBox x:Name="DataCollectionCheckBox" Content="允许数据收集" 
                                  Checked="DataCollectionCheckBox_Checked" Unchecked="DataCollectionCheckBox_Unchecked"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <CheckBox x:Name="CloudSyncCheckBox" Content="允许云同步" 
                                  Checked="CloudSyncCheckBox_Checked" Unchecked="CloudSyncCheckBox_Unchecked"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <CheckBox x:Name="AnalyticsCheckBox" Content="允许统计分析" 
                                  Checked="AnalyticsCheckBox_Checked" Unchecked="AnalyticsCheckBox_Unchecked"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <CheckBox x:Name="ShareStatsCheckBox" Content="分享学习统计" 
                                  Checked="ShareStatsCheckBox_Checked" Unchecked="ShareStatsCheckBox_Unchecked"/>
                    </StackPanel>
                    <TextBlock Text="这些设置控制应用程序如何处理您的个人数据和学习信息。您可以随时更改这些选项。" 
                               TextWrapping="Wrap" Margin="10" Foreground="Gray"/>
                </StackPanel>

                <!-- Update Settings -->
                <TextBlock Text="更新设置" FontSize="18" FontWeight="Bold" Margin="10"/>
                <StackPanel Margin="20">
                    <TextBlock x:Name="VersionLabel" Text="当前版本: v2.7.0" 
                               Margin="10" FontWeight="Bold"/>
                    <Button Content="检查更新" Click="CheckUpdateButton_Click" 
                            Width="180" Height="50" Margin="10"/>
                    <TextBlock Text="点击检查更新按钮将会连接到服务器检查是否有新版本可用。如果有新版本，程序会自动下载并安装。" 
                               TextWrapping="Wrap" Margin="10" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="10">
            <Button Content="保存设置" Click="SaveButton_Click" 
                    Width="160" Height="45" Margin="10"
                    Style="{StaticResource AccentButtonStyle}"/>
            <Button Content="返回" Click="BackButton_Click" 
                    Width="120" Height="40" Margin="10"/>
        </StackPanel>
    </Grid>
</Page>
