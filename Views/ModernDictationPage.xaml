<Page
    x:Class="English_Listen_WinUI.Views.ModernDictationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:English_Listen_WinUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20" Background="{ThemeResource SystemControlAcrylicElementBrush}">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="现代英语听写" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="准备开始" FontSize="16" VerticalAlignment="Center" Foreground="Gray"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Padding="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Word List -->
            <StackPanel Grid.Column="0" Spacing="20">
                <TextBlock Text="单词列表" FontSize="18" FontWeight="SemiBold"/>
                
                <TextBox x:Name="WordsTextBox" 
                         Header="输入单词（每行一个）"
                         PlaceholderText="输入单词，每行一个..."
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="200"
                         TextChanged="WordsTextBox_TextChanged"/>
                
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="加载示例" Click="LoadExampleButton_Click" Style="{ThemeResource AccentButtonStyle}"/>
                    <Button Content="清空" Click="ClearButton_Click"/>
                </StackPanel>

                <TextBlock Text="设置" FontSize="18" FontWeight="SemiBold" Margin="0,20,0,0"/>
                
                <StackPanel Spacing="15">
                    <NumberBox x:Name="IntervalNumberBox"
                               Header="朗读间隔（秒）"
                               Minimum="1"
                               Maximum="30"
                               Value="5"
                               SpinButtonPlacementMode="Inline"
                               ValueChanged="IntervalNumberBox_ValueChanged"/>
                    
                    <ToggleSwitch x:Name="RandomOrderToggle"
                                  Header="随机顺序"
                                  OffContent="顺序"
                                  OnContent="随机"
                                  Toggled="RandomOrderToggle_Toggled"/>
                </StackPanel>
            </StackPanel>

            <!-- Center Panel - Divider -->
            <Rectangle Grid.Column="1" Width="1" Fill="LightGray" Margin="20,0"/>

            <!-- Right Panel - Dictation Interface -->
            <StackPanel Grid.Column="2" Spacing="30">
                <TextBlock Text="听写界面" FontSize="18" FontWeight="SemiBold"/>
                
                <!-- Current Word Display -->
                <Border Background="{ThemeResource SystemControlAcrylicElementBrush}" 
                        CornerRadius="12" 
                        Padding="30"
                        BorderThickness="1"
                        BorderBrush="LightGray">
                    <StackPanel Spacing="15" HorizontalAlignment="Center">
                        <TextBlock x:Name="CurrentWordText" 
                                   Text="等待开始..." 
                                   FontSize="32" 
                                   FontWeight="Bold" 
                                   TextAlignment="Center"
                                   Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
                        
                        <TextBlock x:Name="ProgressText" 
                                   Text="0/0" 
                                   FontSize="16" 
                                   TextAlignment="Center"
                                   Foreground="Gray"/>
                        
                        <TextBlock x:Name="CountdownText" 
                                   Text="" 
                                   FontSize="18" 
                                   TextAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Control Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                    <Button x:Name="StartButton" 
                            Content="开始测试" 
                            Click="StartButton_Click"
                            Style="{ThemeResource AccentButtonStyle}"
                            FontSize="16"/>
                    
                    <Button x:Name="StopButton" 
                            Content="停止" 
                            Click="StopButton_Click"
                            FontSize="16"
                            IsEnabled="False"/>
                    
                    <Button x:Name="PauseButton" 
                            Content="暂停" 
                            Click="PauseButton_Click"
                            FontSize="16"
                            IsEnabled="False"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <Button x:Name="PreviousButton" 
                            Content="上一个" 
                            Click="PreviousButton_Click"
                            FontSize="14"
                            IsEnabled="False"/>
                    
                    <Button x:Name="RepeatButton" 
                            Content="重复" 
                            Click="RepeatButton_Click"
                            FontSize="14"
                            IsEnabled="False"/>
                    
                    <Button x:Name="NextButton" 
                            Content="下一个" 
                            Click="NextButton_Click"
                            FontSize="14"
                            IsEnabled="False"/>
                </StackPanel>

                <!-- Status Indicators -->
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <ProgressRing x:Name="SpeakingIndicator" 
                                  IsActive="False" 
                                  Width="30" 
                                  Height="30"
                                  Visibility="Collapsed"/>
                    
                    <TextBlock x:Name="SpeakingStatusText" 
                               Text="" 
                               FontSize="14" 
                               TextAlignment="Center"
                               Foreground="Gray"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Padding="20" Background="{ThemeResource SystemControlAcrylicElementBrush}">
            <TextBlock Text="现代英语听写系统 - 简洁高效的英语学习工具" 
                       FontSize="14" 
                       HorizontalAlignment="Center"
                       Foreground="Gray"/>
        </Grid>
    </Grid>
</Page>