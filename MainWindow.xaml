<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="English_Listen_WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:English_Listen_WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="English Listen - 英语听写训练">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <!-- Toast notification card - bottom right -->
        <Border x:Name="ToastBorder"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,60"
                Canvas.ZIndex="100"
                Visibility="Collapsed"
                CornerRadius="10"
                MaxWidth="360"
                RenderTransformOrigin="1,0.5">
            <Border.Background>
                <SolidColorBrush Color="{ThemeResource SystemAccentColor}" Opacity="0.95"/>
            </Border.Background>
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" X="100"/>
            </Border.RenderTransform>
            <Grid Margin="18,14,18,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="ToastTitle" Grid.Row="0"
                           Foreground="White" FontWeight="SemiBold" FontSize="14"
                           TextTrimming="CharacterEllipsis"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="ToastMessage" Grid.Row="1"
                           Foreground="White" FontSize="13" Opacity="0.9"
                           TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                           MaxLines="4"/>
            </Grid>
        </Border>

        <NavigationView x:Name="MainNavigationView"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="True"
                        IsBackButtonVisible="Auto"
                        IsBackEnabled="True"
                        SelectionChanged="NavigationView_SelectionChanged"
                        ItemInvoked="NavigationView_ItemInvoked">
            
            <!-- Menu Items -->
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Home" Content="主页" Tag="HomePage" />
                <NavigationViewItem Icon="Library" Content="查看单词" Tag="WordsPage" />
                <NavigationViewItem Icon="Page2" Content="背单词" Tag="MemorizePage" />
                <NavigationViewItem Icon="People" Content="用户管理" Tag="UserPage" />
                <NavigationViewItem Icon="Map" Content="学习进度" Tag="ProgressPage" />
            </NavigationView.MenuItems>
            
            <!-- Footer Menu Items -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Icon="Help" Content="帮助" Tag="HelpPage" />
                <NavigationViewItem Icon="ContactInfo" Content="关于" Tag="AboutPage" />
            </NavigationView.FooterMenuItems>

            <!-- Content Frame -->
            <Frame x:Name="ContentFrame" />
            
        </NavigationView>
    </Grid>
</Window>
