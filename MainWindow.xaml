<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="English_Listen_WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:English_Listen_WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="English Listen - 英语听写训练">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView x:Name="MainNavigationView"
                    PaneDisplayMode="Left"
                    IsSettingsVisible="True"
                    IsBackButtonVisible="Auto"
                    IsBackEnabled="True"
                    SelectionChanged="NavigationView_SelectionChanged"
                    ItemInvoked="NavigationView_ItemInvoked">
        
        <!-- Menu Items -->
        <NavigationView.MenuItems>
            <NavigationViewItem Icon="Home" Content="主页" Tag="HomePage" />
            <NavigationViewItem Icon="Library" Content="查看单词" Tag="WordsPage" />
            <NavigationViewItem Icon="People" Content="用户管理" Tag="UserPage" />
            <NavigationViewItem Icon="Map" Content="学习进度" Tag="ProgressPage" />
        </NavigationView.MenuItems>
        
        <!-- Footer Menu Items -->
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Icon="Help" Content="帮助" Tag="HelpPage" />
            <NavigationViewItem Icon="ContactInfo" Content="关于" Tag="AboutPage" />
        </NavigationView.FooterMenuItems>

        <!-- Content Frame -->
        <Frame x:Name="ContentFrame" />
        
    </NavigationView>
</Window>
